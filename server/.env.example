# MongoDB Atlas or local MongoDB connection URI
MONGO_URI=mongodb://127.0.0.1:27017/eventora

# Use a long, random value in production
JWT_SECRET=replace-with-a-long-random-secret

# Gmail SMTP credentials (use a Google App Password)
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASS=your-gmail-app-password

# Comma-separated allowed frontend origins
CLIENT_URL=http://localhost:5173

# Render supplies PORT automatically; this is useful locally.
PORT=5000
